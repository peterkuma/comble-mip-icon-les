#!/usr/bin/env python3
'''Plot 2D fields from ICON LES.

Usage: plot_clouds INPUT FORCING GRID N OUTPUT

Arguments:

  INPUT    Input file (NetCDF). This can be either mean.nc or inst.nc output of ICON, or dephy_mean.nc or dephy_2d.nc output of icon2dephy.
  FORCING  COMBLE forcing file (NetCDF).
  GRID     ICON grid definition file (NetCDF).
  N        Time step.
  OUTPUT   Output plot file (PDF).
'''

import sys
import numpy as np
import scipy.interpolate
import ds_format as ds
import matplotlib.pyplot as plt
import matplotlib as mpl
from matplotlib import ticker
import aquarius_time as aq

R = 6371e3

mpl.rc('font', family='Open Sans')
mpl.rc('axes', linewidth=0.3)
#mpl.rc('axes', grid=True)
mpl.rc('lines', linewidth=1.2)
mpl.rc('xtick.major', width=0.3)
mpl.rc('ytick.major', width=0.3)
mpl.rc('legend', framealpha=1)
mpl.rc('legend', facecolor='white')
mpl.rc('legend', edgecolor='none')
mpl.rc('legend', fancybox=False)
mpl.rc('legend', fontsize=8)
mpl.rc('grid', color='k')
mpl.rc('grid', alpha=0.2)
mpl.rc('grid', lw=0.1)

VARS = [
	'time', 'rho', 'alt', 'qc', 'qi', 'qg', 'qr', 'qs', 'w', 'od', 'z_mc',
	'z_ifc', 'x', 'y', 'lwp', 'iwp', 'alb', 'opt', 'pr', 'hfls', 'hfss', 'us',
	'vs', 'ustar'
]
QVARS = ['qc', 'qi', 'qg', 'qr', 'qs']

if __name__ == '__main__':
	if len(sys.argv) != 6:
		sys.stderr.write(sys.modules[__name__].__doc__)
		sys.exit(1)
	input_ = sys.argv[1]
	forcing = sys.argv[2]
	grid = sys.argv[3]
	n = int(sys.argv[4])
	output = sys.argv[5]

	d = ds.read(input_, VARS, jd=True, sel={'time': n})

	t = d['time']
	rho = d['rho'][::-1] if 'rho' in d else None
	if 'alt' in d:
		zfull = d['alt'][::-1]
		zhalf = None
	elif 'z_mc' in d:
		zfull = d['z_mc'][::-1]
		zhalf = d['z_ifc'][::-1]
	else:
		zfull = None
		zhalf = None
	d2 = {}
	for var in QVARS:
		if var in d:
			d2[var] = d[var][::-1]
	if 'qg' in d2 and 'qr' in d2 and 'qs' in d2:
		d2['qp'] = d2['qg'] + d2['qr'] + d2['qs']
	if 'w' in d:
		d2['w'] = d['w'][::-1]

	g = ds.read(grid, [
		'cell_circumcenter_cartesian_x',
		'cell_circumcenter_cartesian_y'
	])

	f = ds.read(forcing, ['time', 'lat_ref', 'lon_ref'])

	lat = np.interp(t, f['time'], f['lat_ref'])
	lon = np.interp(t, f['time'], f['lon_ref'])

	xg = g['cell_circumcenter_cartesian_x']
	yg = g['cell_circumcenter_cartesian_y']

	xmin = np.min(xg)
	xmax = np.max(xg)
	ymin = np.min(yg)
	ymax = np.max(yg)

	if zfull is not None and zfull.ndim == 1:
		dz_g = np.diff(zfull)
		k_g = np.searchsorted(zfull, 1000)
	else:
		dz_g = None
		k_g = None

	ncells = ds.dim(d, 'ncells')

	for var in QVARS + ['qp']:
		if var in d2:
			print('Processing %s...' % var)
			tmp = np.zeros(ncells)
			for i in range(ncells):
				dz = dz_g if dz_g is not None else np.diff(zhalf[:,i])
				tmp[i] = np.sum(d2[var][:len(dz),i]*rho[:len(dz),i]*dz)
			d2[var] = tmp

	if 'w' in d2:
		print('Processing w...')
		tmp = np.zeros(ncells)
		for i in range(ncells):
			dz = dz_g if dz_g is not None else np.diff(zhalf[:,i])
			k = k_g if k_g is not None else np.searchsorted(zfull[:,i], 1000)
			tmp[i] = np.sum(d2['w'][:k,i]*dz[:k])/np.sum(dz[:k])
		d2['w'] = tmp

	if 'x' in d and 'y' in d:
		x = d['x']
		y = d['y']
	else:
		nxy = int(np.sqrt(ds.dim(d, 'ncells')))
		x = np.linspace(xmin, xmax, nxy)
		y = np.linspace(ymin, ymax, nxy)
		xm, ym = np.meshgrid(x, y)

	first = True
	def plot_field(
		gs, cgs, data, label, cmap, alpha,
		vmin, vmax, dv,
		cmin, cmax, dc
	):
		global first
		if 'x' in d and 'y' in d:
			z = data
		else:
			z = scipy.interpolate.griddata((xg, yg), data, (xm, ym))
		plt.subplot(gs)
		levels = np.arange(vmin, vmax + dv, dv)
		plt.contourf(x*1e-3, y*1e-3, z,
			alpha=alpha,
			cmap=cmap,
			antialiased=True,
			levels=levels,
			extend='max',
		)
		plt.gca().set_aspect('equal')
		cax = plt.subplot(cgs)
		cb = plt.colorbar(
			shrink=0.5,
			label=label,
			cax=cax,
		)
		cb.set_ticks(np.arange(cmin, cmax + dc, dc))
		plt.subplot(gs)
		if first:
			plt.xlabel('X (km)')
			plt.ylabel('Y (km)')
			plt.title('%s, %.1f°N %.1f°E' % (
				aq.to_datetime(t + 1/(60*60*24)).strftime('%Y-%m-%d %H:%M'),
				lat,
				lon,
			), y=0.9)
		first = False
		# ds.write('out.nc', {
		# 	'time': t,
		# 	'x': ox,
		# 	'y': oy,
		# 	'alb': z.T.reshape([1] + list(z.T.shape)),
		# 	'.': {
		# 		'time': d['.']['time'],
		# 		'x': {
		# 			'.dims': ['x'],
		# 			'standard_name': 'x',
		# 			'units': 'm',
		# 		},
		# 		'y': {
		# 			'.dims': ['y'],
		# 			'standard_name': 'y',
		# 			'units': 'm',
		# 		},
		# 		'alb': {
		# 			'.dims': ['time', 'x', 'y'],
		# 			'standard_name': 'pseudo-albedo',
		# 			'units': '1',
		# 		},
		# 	}
		# })

	cmap_gs = plt.get_cmap('Greys')
	cmap_r = plt.get_cmap('Reds')
	cmap_b = plt.get_cmap('Blues')
	cmap_g = plt.get_cmap('Greens')
	cmap_rb = plt.get_cmap('bwr')
	cmap_cw = plt.get_cmap('coolwarm')
	cmap_r.set_over(cmap_r(1.))
	cmap_b.set_over(cmap_b(1.))
	cmap_g.set_over(cmap_g(1.))

	nrows = \
		int('qc' in d2 and 'qi' in d2) + \
		int('lwp' in d and 'iwp' in d) + \
		int('pr' in d or 'qp' in d2) + \
		int('w' in d2) + \
		int('opt' in d or 'od' in d) + \
		int('od' in d or 'alb' in d) + \
		int('hfls' in d) + \
		int('hfss' in d) + \
		int('us' in d) + \
		int('vs' in d) + \
		int('ustar' in d)

	if 'qc' in d2 and 'qi' in d2 or 'lwp' in d and 'iwp' in d:
		ncbars = 2
		width_ratios = [0.82, 0.05, 0.08, 0.05]
		ncols = 4
	else:
		ncbars = 1
		width_ratios = [0.82, 0.05]
		ncols = 2

	plt.figure(figsize=(4 + ncbars, nrows*4))

	gs = plt.GridSpec(nrows, ncols, width_ratios=width_ratios)

	i = 0

	if 'qc' in d2 and 'qi' in d2:
		plot_field(
			gs[i], gs[i+1], d2['qc']*1e3,
			'Cloud liquid (g m$^{-2}$)',
			cmap_r, 0.5,
			0, 500, 50,
			0, 500, 50,
		)
		plot_field(
			gs[i], gs[i+3], d2['qi']*1e3,
			'Cloud ice (g m$^{-2}$)',
			cmap_b, 0.5,
			0, 500, 50,
			0, 500, 50,
		)
		i += ncols

	if 'lwp' in d and 'iwp' in d:
		plot_field(
			gs[i], gs[i+1], d['lwp']*1e3,
			'Liquid water path (g m$^{-2}$)',
			cmap_r, 0.5,
			0, 1000, 50,
			0, 1000, 100,
		)
		plot_field(
			gs[i], gs[i+3], d['iwp']*1e3,
			'Ice water path (g m$^{-2}$)',
			cmap_b, 0.5,
			0, 1000, 50,
			0, 1000, 100,
		)
		i += ncols

	if 'qp' in d2:
		plot_field(
			gs[i], gs[i+1], d2['qp']*1e3,
			'Vert.-int. precipitation (g m$^{-2}$)',
			cmap_g, 1,
			0, 2000, 100,
			0, 2000, 200,
		)
		i += ncols

	if 'pr' in d:
		plot_field(
			gs[i], gs[i+1], d['pr']*1e6,
			'Precipitation (mg m$^{-2}$ s$^{-2}$)',
			cmap_g, 1,
			0, 1000, 50,
			0, 1000, 100,
		)
		i += ncols

	if 'w' in d2:
		plot_field(
			gs[i], gs[i+1], d2['w'],
			'Vertical wind 0–1 km (ms$^{-1}$)',
			cmap_rb, 1,
			-3, 3, 0.25,
			-3, 3, 0.5,
		)
		i += ncols

	if 'opt' in d or 'od' in d:
		opt = d['opt'] if 'opt' in d else d['od']
		plot_field(
			gs[i], gs[i+1], opt,
			'Optical depth',
			cmap_cw, 1,
			0, 40, 1,
			0, 40, 5,
		)
		i += ncols

	if 'alb' in d or 'od' in d:
		palb = d['alb'] if 'alb' in d else d['od']/(d['od'] + 13)
		plot_field(
			gs[i], gs[i+1], palb,
			'Pseudo-albedo',
			cmap_cw, 1,
			0, 0.9, 0.05,
			0, 0.9, 0.1,
		)
		i += ncols

	if 'hfss' in d:
		plot_field(
			gs[i], gs[i+1], d['hfss'],
			'Surface sensible heat flux (W m$^{-2}$)',
			cmap_r, 1,
			0, 500, 10,
			0, 500, 50,
		)
		i += ncols

	if 'hfls' in d:
		plot_field(
			gs[i], gs[i+1], d['hfls'],
			'Surface latent heat flux (W m$^{-2}$)',
			cmap_r, 1,
			0, 500, 10,
			0, 500, 50,
		)
		i += ncols

	if 'us' in d:
		us0 = np.nanmean(d['us'])
		plot_field(
			gs[i], gs[i+1], d['us'] - us0,
			'Surf. eastward wind anomaly (m s$^{-1}$)',
			cmap_cw, 1,
			-8, 8, 0.5,
			-8, 8, 1,
		)
		plt.text(0.5, 0.94, '$\\bar{u}$ = %.1f m s$^{-1}$' % us0,
			transform=plt.gca().transAxes,
			ha='center',
		)
		i += ncols

	if 'vs' in d:
		vs0 = np.nanmean(d['vs'])
		plot_field(
			gs[i], gs[i+1], d['vs'] - vs0,
			'Surf. northward wind anomaly (m s$^{-1}$)',
			cmap_cw, 1,
			-8, 8, 0.5,
			-8, 8, 1,
		)
		plt.text(0.5, 0.94, '$\\bar{v}$ = %.1f m s$^{-1}$' % vs0,
			transform=plt.gca().transAxes,
			ha='center',
		)
		i += ncols

	if 'ustar' in d:
		plot_field(
			gs[i], gs[i+1], d['ustar'],
			'Surface friction velocity (m s$^{-1}$)',
			cmap_g, 1,
			0, 1, 0.1,
		 	0, 1, 0.2,
		)
		i += ncols

	plt.savefig(output, bbox_inches='tight', dpi=300)

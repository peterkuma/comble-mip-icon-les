#!/usr/bin/env bash
#
# SCM run script for ARM DEPHY case:
#
# Details: Input data is only defined to 20km. Therefore use ICON-D2 vertical
# grid.
#

set -ex

# ----------------------------------------------------------------------------
# create ICON master namelist
# ----------------------------------------------------------------------------

nl_master () {
	cat <<EOF
&master_nml
 lrestart                    = ${lrestart}                        ! .TRUE.=current experiment is resumed
/
&master_model_nml
 model_type                  =                          1         ! identifies which component to run (atmosphere,ocean,...)
 model_name                  =                      "ATMO"        ! character string for naming this component.
 model_namelist_filename     = "icon.namelist"		              ! file name containing the model namelists
 model_min_rank              =                          1         ! start MPI rank for this model
 model_max_rank              =                      65536         ! end MPI rank for this model
 model_inc_rank              =                          1         ! stride of MPI ranks
/

&master_time_control_nml
 experimentStartDate  = "$start_date"
 experimentStopDate   = "$end_date"
/
EOF
}

# ----------------------------------------------------------------------------
# model namelists
# ----------------------------------------------------------------------------
# For a complete list see doc/Namelist_overview.pdf

nl () {
	cat <<EOF
&parallel_nml
 nproma         = 5                   ! MS: was on 752, but this is probably for vector machines (see errorlog)
 p_test_run     = .false.
 num_io_procs   = 2                   ! number of I/O processors: in Martin Köhler's runscripts for SCM 1, for LES 2
 l_test_openmp  = .false.
 l_log_checks   = .false.
 proc0_shift    = 1                   ! 1: use first CPU for management, 0: only use VEs (delete VHs in mpirun)
 use_omp_input  = .true.
!l_fast_sum     = .TRUE.              ! .TRUE. speeds up global sums in apply_ls_forcing (most CPU time!)
/

&grid_nml
 dynamics_grid_filename = "${atmo_dyn_grids}",
 corio_lat              = ${corio_lat}
 is_plane_torus         = .TRUE.
 l_scm_mode             = .TRUE.      ! main logical to turn on SCM mode
/                                     ! note: if ldynamics off this transitions to LES or CRM

&SCM_nml
 i_scm_netcdf  = 2                    ! read initial profiles and forcings from netcdf - universal format
 lscm_read_tke = ${lscm_read_tke}     ! read initial tke from netcdf
 lscm_read_z0  = ${lscm_read_z0}      ! read initial z0 from netcdf
 lscm_random_noise = .TRUE.           ! add random noise at init
 scm_sfc_mom   = ${scm_sfc_mom}       ! 0: TURBTRANS: no prescribed u*
 scm_sfc_temp  = ${scm_sfc_temp}      ! 0: TERRA:     no prescribed sensible heat flux at surface
 scm_sfc_qv    = ${scm_sfc_qv}        ! 0: TERRA:     no prescribed latent heat flux at surface
/                                     ! 3: qv,sat(Tg)

&io_nml
 lkeep_in_sync  = .true.
 lflux_avg      = .FALSE.      ! false: accumulated fluxes
 dt_checkpoint  = 9600
/

&run_nml
 num_lev        = 180 !180 !100 !170 !120        ! number of full levels of vertical grid
 dtime          = ${dtime}     ! timestep in seconds
 nsteps         = ${nsteps}
 ldynamics      = .TRUE.       ! compute adiabatic dynamic tendencies
 ltransport     = .TRUE.
 ntracer        = 5            ! default: 0
 iforcing       = 3            ! 3: NWP forcing; 6:inhecham forcing
 ltestcase      = .TRUE.       ! run testcase
 ltimer         = .TRUE.
 timers_level   = 10           ! 10: sufficiently detailed output
 msg_level      = ${msg_level} ! detailed report during integration (15 for SCM/LES output)
 output         = 'nml','totint'
/

&nwp_phy_nml
 inwp_gscp       = ${inwp_gscp}
 inwp_convection = ${inwp_convection} ! 1:Tiedtke/Bechtold, 0:off
 inwp_radiation  = ${inwp_radiation}  ! 1:RRTM radiation
 inwp_cldcover   = ${inwp_cldcover}   ! 3: clouds from COSMO SGS cloud scheme 0:off
 inwp_turb       = ${inwp_turb}       ! 1: TKE diffusion and transfer
 inwp_satad      = ${inwp_satad}
 inwp_sso        = ${inwp_sso}
 inwp_gwd        = ${inwp_gwd}
 inwp_surface    = 0            ! 0: none; 1: TERRA
 icapdcycl	 = 0            ! apply CAPE modification to improve diurnalcycle over tropical land (optimizes NWP scores)
				! MS: 3 is ECMWF working version for land and no correction for water (should be ideal --> SCM)
				! MS: EDIT: only works for convection which is turned off in LES --> 0
 latm_above_top  = .TRUE.       ! needed for radiation routine
 itype_z0        = 2            ! 1: extpar, 2: land-cover dependent, 3: land-cover + sub-grid orography, see const_z0
				! MS: irrelevant if lconst_z0 in turbdiff_nml is enabled
 dt_rad	         = 1800.        ! Default: 1800   ! M. Koehler: 1440
 dt_conv         = 600.         ! Default: 600    ! M. Koehler: 360
 dt_sso	         = 600.         ! Default: 1200   ! M. Koehler: 720
 dt_gwd	         = 600.         ! Default: 1200   ! M. Koehler: 720
 icpl_rad_reff   = 1		! MS: coupling reff with radiation based on reff by icalcreff; all hydrometeors combined in liquid or frozen phase
 icalc_reff	 = 100		! MS: sets icalc_reff consistent with microphysics (icalc_reff = inwp_gscp)
! ithermo_water	 = 1		! MS: temperature dependent latent heat in saturation and microphysics; good for gscp=4 (Maike)
/

&radiation_nml
 irad_o3         = 9
 albedo_type     = 1            ! 1: table, 2: Modis albedo (attention: requires data update at midnight)
 direct_albedo   = 4
 direct_albedo_water = 3
 albedo_whitecap = 1
 izenith = 6 ! 4: default, 6: fixed coszenith
 cos_zenith_fixed = 0.0 ! 0.0: night, no solar
 vmr_co2         = 420.e-06     ! COMBLE specification
 vmr_ch4         = 1800.e-09
 vmr_n2o         = 322.0e-09
 vmr_o2          = 0.20946
 vmr_cfc11       = 240.e-12
 vmr_cfc12       = 532.e-12
 ecRad_data_path = '${ecRad_data_path}'
/

&les_nml
 isrfc_type      = 10           ! 10: boundary conditions for LES like in SCM
/

&nh_testcases_nml
 w_perturb       = 0.0          ! random perturbation to start LES circulation (0.05 default, 0.1 faster start)
 th_perturb      = 0.1          ! random perturbation to start LES circulation (0.2 default)
/

&ls_forcing_nml
 is_subsidence_moment = ${is_subsidence_moment}
 is_subsidence_heat   = ${is_subsidence_heat}
 is_advection         = ${is_advection}
 is_advection_uv      = ${is_advection_uv}
 is_advection_tq      = ${is_advection_tq}
 is_geowind           = ${is_geowind}
 is_rad_forcing       = ${is_rad_forcing}
 is_nudging           = ${is_nudging}
 is_nudging_uv        = ${is_nudging_uv}
 is_nudging_t         = ${is_nudging_t}
 is_nudging_q         = ${is_nudging_q}
 nudge_start_height_uv= ${nudge_start_height_uv}
 nudge_full_height_uv = ${nudge_full_height_uv}
 nudge_start_height_t = ${nudge_start_height_t}
 nudge_full_height_t  = ${nudge_full_height_t}
 nudge_start_height_q = ${nudge_start_height_q}
 nudge_full_height_q  = ${nudge_full_height_q}
 dt_relax_uv          = ${dt_relax_uv}
 dt_relax_t           = ${dt_relax_t}
 dt_relax_q           = ${dt_relax_q}
 is_sim_rad           = ${is_sim_rad}
/

&turbdiff_nml
 tkhmin        = 0.6
 tkmmin        = 0.75
 pat_len       = 750.
 c_diff        = 0.2
 ltkesso       = .TRUE.
!frcsmot       = 0.2    ! these 2 switches together apply vertical smoothing of the TKE source terms
!imode_frcsmot = 2      ! in the tropics (only), which reduces the moist bias in the tropical lower troposphere
 ! use horizontal shear production terms with 1/SQRT(Ri) scaling to prevent unwanted side effects:
 itype_sher    = 0
 ltkeshs       = .false.
 a_hshr        = 2.0
 lconst_z0     = ${lconst_z0}    ! TRUE: constant z0, typical for idealized LES cases ( or .FALSE. and itype_z0=2)
 const_z0      = ${const_z0}     ! ocean: about 0.0001m (better: user Charnock formula from turb_transder.f90)
 icldm_tran    = 2
 icldm_turb    = 2
 rlam_heat     = 10.0
 rat_sea       = 0.8
 alpha1        = 0.125
/

&nwp_tuning_nml
 itune_albedo     = 1
 tune_gkwake      = 1.5
 tune_gfrcrit     = 0.425
 tune_grcrit      = 0.5
 tune_gkdrag      = 0.16
 tune_zvz0i       = 0.85
 tune_box_liq_asy = 3.25
 tune_minsnowfrac = 0.2
 tune_gfluxlaun   = 3.75e-3
 tune_rcucov      = 0.075
 tune_rhebc_land  = 0.825
 lcalib_clcov     = .FALSE. !no tuning of cloud cover!
 tune_sbmccn      = ${tune_sbmccn}
!tune_entrorg     = 7.4E-3 ! is 1.85e-3 normally
!tune_rdepths     = 60000.
!tune_texc        = 0.2 !0.125
!tune_qexc        = 1.e-4 !1.25e-2
!tune_gust_factor = 7.0
!icpl_turb_clc    = 2
!tune_box_liq     = 0.04
/

&diffusion_nml
 hdiff_order      = 5
 itype_vn_diffu   = 1
 itype_t_diffu    = 2
 hdiff_efdt_ratio = 24.
 hdiff_smag_fac   = 0.025
 lhdiff_vn        = .TRUE.
 lhdiff_temp      = .TRUE.
/

&nonhydrostatic_nml
 itime_scheme    = 4
 vwind_offctr    = 0.2
!damp_height     = 12250.
 damp_height     = 9000.
!rayleigh_coeff  = 0.5
 rayleigh_coeff  = 5.0
!divdamp_order   = 24
 divdamp_fac     = 0.004
 divdamp_type    = 32
 l_open_ubc      = .false.
 igradp_method   = 3
 l_zdiffu_t      = .true.
 thslp_zdiffu    = 0.02
 thhgtd_zdiffu   = 125.
 htop_moist_proc = 22500.
 hbot_qvsubstep  = 22500.
 exner_expol     = 0.333
 iadv_rhotheta   = 2
 ivctype         = 2
 ndyn_substeps   = ${ndyn_substeps}
!rayleigh_coeff  = 5.0
/

&sleve_nml
 decay_exp       = 1.2
 decay_scale_1   = 4000.
 decay_scale_2   = 2500.
 flat_height     = 16000.
 itype_laydistr  = 1
 min_lay_thckn   = 14. !12.
 stretch_fac     = 0.65
 top_height      = 20000.
!top_height      = 22000.
 max_lay_thckn   = 40. !25.   !MS: this only works if max_lay_thckn > 2*min_lay_thckn and max_lay_thckn < 0.5*htop_thcknlimit
 htop_thcknlimit = 5500.
!stretch_fac     = 0.9
/

&extpar_nml
 itopo          = 0         ! 0: analytical topo; 1: topography/ext. data read from file
/

&dynamics_nml
 iequations     = 3
 idiv_method    = 1
 divavg_cntrwgt = 0.50
 lcoriolis      = .TRUE.   ! MS: Maike says it should be true, test it; Martin Koehler: SCM attention: .TRUE. distroys U-profile!!
/

!namelist for editing the default values of the two moment microphysics scheme
&twomom_mcrph_nml
 i2mom_solver	= 0             ! MS: 0: explicit solver; 1: semi-implicit solver
 iicephase = ${iicephase}
 alpha_spacefilling = ${alpha_spacefilling}
/

&output_nml
 output_time_unit = 2                        ! 1: seconds
 output_bounds    = 0., 10000000., 10.       ! start, end, increment
 mode             = 1                        ! 1: forecast
 steps_per_file   = 10000
 include_last     = .TRUE.
 operation        = mean
 output_filename  = 'mean'
 filename_format  = "<output_filename>"
 ml_varlist       = ${mean_ml_varlist}
!APtest             'reff_qc', 'reff_qr', 'dbz'
 output_grid      = .TRUE.
/

&output_nml
 output_time_unit = 2                        ! 1: seconds
 output_bounds    = 0., 10000000., 10.       ! start, end, increment
 mode             = 1                        ! 1: forecast
 steps_per_file   = 10000
 include_last     = .TRUE.
 output_filename  = 'inst'
 filename_format  = "<output_filename>"
 ml_varlist       = ${inst_ml_varlist}
 output_grid      = .TRUE.
/

&output_nml
 output_time_unit = 2                        ! 1: seconds
 output_bounds    = 0., 10000000., 10.       ! start, end, increment
 mode             = 1                        ! 1: forecast
 steps_per_file   = 10000
 include_last     = .TRUE.
 output_filename  = 'winds'
 filename_format  = "<output_filename>"
 hl_varlist       = 'rh', 'u','v','w'
 h_levels         =  0, 20.0, 45.0, 75.0, 110.0, 150.0, 190.0, 230.0, 270.0, 310.0, 350.0, 390.0, 430.0,
                     470.0, 510.0, 550.0, 590.0, 630.0, 670.0, 710.0, 750.0, 790.0, 830.0, 870.0, 910.0,
                     950.0, 990.0, 1030.0, 1070.0, 1110.0, 1150.0, 1190.0, 1230.0, 1270.0, 1310.0, 1350.0,
                     1390.0, 1430.0, 1470.0, 1510.0, 1550.0, 1590.0, 1630.0, 1670.0, 1710.0, 1750.0, 1790.0,
                     1830.0, 1870.0, 1910.0, 1950.0, 1990.0, 2030.0, 2070.0, 2110.0, 2150.0, 2190.0, 2230.0,
                     2270.0, 2310.0, 2350.0, 2390.0, 2430.0, 2470.0, 2510.0, 2550.0, 2590.0, 2630.0, 2670.0,
                     2710.0, 2750.0, 2790.0, 2830.0, 2870.0, 2910.0, 2950.0, 2990.0, 3030.0, 3070.0, 3110.0,
                     3150.0, 3190.0, 3230.0, 3270.0, 3310.0, 3350.0, 3390.0, 3430.0, 3470.0, 3510.0, 3550.0,
                     3590.0, 3630.0, 3670.0, 3710.0, 3750.0, 3790.0, 3830.0, 3870.0, 3910.0, 3950.0, 3990.0,
                     4030.0, 4070.0, 4110.0, 4150.0, 4190.0, 4230.0, 4270.0, 4310.0, 4350.0, 4390.0, 4430.0,
                     4470.0, 4510.0, 4550.0, 4590.0, 4630.0, 4670.0, 4710.0, 4750.0, 4790.0, 4830.0,
                     4870.0, 4910.0, 4950.0, 4990.0, 5030.0, 5070.0, 5110.0, 5150.0, 5190.0, 5230.0,
                     5270.0, 5310.0, 5350.0, 5390.0, 5430.0, 5470.0, 5510.0, 5550.0, 5610.0, 5690.0,
                     5770.0, 5850.0, 5930.0,6010.0, 6090.0, 6170.0, 6250.0, 6330.0, 6410.0, 6490.0,
                     6570.0, 6650.0, 6730.0, 6810.0, 6890.0, 6950.0, 7000.0
 output_grid      = .TRUE.
/

&output_nml
 output_time_unit = 2                        ! 1: seconds
 output_bounds    = 0., 10000000., 60.       ! start, end, increment
 mode             = 1                        ! 1: forecast
 steps_per_file   = 10000
 include_last     = .TRUE.
 output_filename  = 'hourly'
 filename_format  = "<output_filename>"
 h_levels         =  0, 20.0, 45.0, 75.0, 110.0, 150.0, 190.0, 230.0, 270.0, 310.0, 350.0, 390.0, 430.0,
                     470.0, 510.0, 550.0, 590.0, 630.0, 670.0, 710.0, 750.0, 790.0, 830.0, 870.0, 910.0,
                     950.0, 990.0, 1030.0, 1070.0, 1110.0, 1150.0, 1190.0, 1230.0, 1270.0, 1310.0, 1350.0,
                     1390.0, 1430.0, 1470.0, 1510.0, 1550.0, 1590.0, 1630.0, 1670.0, 1710.0, 1750.0, 1790.0,
                     1830.0, 1870.0, 1910.0, 1950.0, 1990.0, 2030.0, 2070.0, 2110.0, 2150.0, 2190.0, 2230.0,
                     2270.0, 2310.0, 2350.0, 2390.0, 2430.0, 2470.0, 2510.0, 2550.0, 2590.0, 2630.0, 2670.0,
                     2710.0, 2750.0, 2790.0, 2830.0, 2870.0, 2910.0, 2950.0, 2990.0, 3030.0, 3070.0, 3110.0,
                     3150.0, 3190.0, 3230.0, 3270.0, 3310.0, 3350.0, 3390.0, 3430.0, 3470.0, 3510.0, 3550.0,
                     3590.0, 3630.0, 3670.0, 3710.0, 3750.0, 3790.0, 3830.0, 3870.0, 3910.0, 3950.0, 3990.0,
                     4030.0, 4070.0, 4110.0, 4150.0, 4190.0, 4230.0, 4270.0, 4310.0, 4350.0, 4390.0, 4430.0,
                     4470.0, 4510.0, 4550.0, 4590.0, 4630.0, 4670.0, 4710.0, 4750.0, 4790.0, 4830.0,
                     4870.0, 4910.0, 4950.0, 4990.0, 5030.0, 5070.0, 5110.0, 5150.0, 5190.0, 5230.0,
                     5270.0, 5310.0, 5350.0, 5390.0, 5430.0, 5470.0, 5510.0, 5550.0, 5610.0, 5690.0,
                     5770.0, 5850.0, 5930.0,6010.0, 6090.0, 6170.0, 6250.0, 6330.0, 6410.0, 6490.0,
                     6570.0, 6650.0, 6730.0, 6810.0, 6890.0, 6950.0, 7000.0
 hl_varlist       =  ${hourly_hl_varlist}
 output_grid      = .TRUE.
/
EOF
}

expname=$1

#ulimit -s unlimited
ulimit -s 2097152
#ulimit -s unlimited
#204800 #2097152
#ulimit -s 204800
#ulimit -c 0
ulimit -c unlimited

starttime=$(date)

#=============================================================================
#
# OpenMP environment variables
# ----------------------------
#ntasks=${SLURM_NTASKS:-1}
#export OMP_NUM_THREADS=${SLURM_CPUS_PER_TASK:-1}
export OMP_NUM_THREADS=2 #4
export ICON_THREADS=${OMP_NUM_THREADS}
export OMP_SCHEDULE=dynamic,1
export OMP_DYNAMIC=false
export OMP_STACKSIZE=128M
#export MV2_ENABLE_AFFINITY=0  # setting for MVAPICH2
#
# MPI variables
# -------------
no_of_nodes=${SLURM_JOB_NUM_NODES:=1}
mpi_procs_pernode=$((${SLURM_JOB_CPUS_PER_NODE%%\(*} / 2 / OMP_NUM_THREADS))
((mpi_total_procs=no_of_nodes * mpi_procs_pernode))
#
# blocking length
# ---------------

#with_mpi="yes"
#with_openmp="no"


#
#=============================================================================

# load local setting, if existing
# -------------------------------
if [ -a ../setting ]
then
  echo "Load Setting"
  . ../setting
fi

# environment variables for the experiment and the target system
# --------------------------------------------------------------
export KMP_AFFINITY="granularity=fine,scatter"
export KMP_LIBRARY="turnaround"
export KMP_KMP_SETTINGS="1"
export MKL_DEBUG_CPU_TYPE="5"
export KMP_LIBRARY="turnaround"
export UCX_IB_ADDR_TYPE="ib_global"
export OMPI_MCA_coll="^ml,hcoll"
export HCOLL_MAIN_IB="mlx5_0:1"
export UCX_NET_DEVICES="mlx5_0:1"
export UCX_TLS="shm,mm,cma,dc_mlx5,dc_x,self"
export UCX_UNIFIED_MODE="y"
export HDF5_USE_FILE_LOCKING="FALSE"
export OMPI_MCA_io="romio321"
export MALLOC_TRIM_THRESHOLD_="-1"
export SLURM_DIST_PLANESIZE="32"
export MKL_ENABLE_INSTRUCTIONS="AVX2"
export OMPI_MCA_btl="self"
export OMPI_MCA_osc="ucx"
export OMPI_MCA_pml="ucx"
export UCX_HANDLE_ERRORS="bt"

START="srun -l --kill-on-bad-exit=1 --nodes=${SLURM_JOB_NUM_NODES:-1} --cpu_bind=v --distribution=block:cyclic --hint=nomultithread --ntasks=$((no_of_nodes * mpi_procs_pernode)) --ntasks-per-node=${mpi_procs_pernode} --cpus-per-task=$(( OMP_NUM_THREADS)) --propagate=STACK,CORE"

#=============================================================================
# load profile
if [ -a  /etc/profile ] ; then
  . /etc/profile
  # load modules
  module purge
  #module load "$loadmodule"
  module list
fi

# ----------------------------------------------------------------------------
# specifiy experiment (idealized simulation)
# ----------------------------------------------------------------------------
case=COMBLE                     # ARM, RICO, BOMEX, GABLS1, FIRE, MPACE, MAGIC


# case specific namelist parameters
. input/case_definition_dephy "$case"

# default LES physics parameters
lrestart=.false.
msg_level=12
inwp_convection=0              # 1:Tiedtke/Bechtold, 0:off
inwp_cldcover=5                # 3: clouds from COSMO SGS cloud scheme 0:off
inwp_turb=5                    # 1: TKE diffusion and transfer
inwp_sso=0
inwp_gwd=0
inwp_gscp=2		       # 5: double moment microphysics with CCN tracer
#is_subsidence_moment=.FALSE.
iicephase=1
alpha_spacefilling=0.01
tune_sbmccn=1.0
lconst_z0=.true.
const_z0=9.0e-04
mean_ml_varlist="'pres_sfc','t_g','umfl_s','vmfl_s','lhfl_s','shfl_s','tvm','tvh','drag_u_grid','drag_v_grid','tqc','tot_prec_rate','ice_gsp_rate','snow_gsp_rate','graupel_gsp_rate','thu_s','thb_s','thb_t','sob_s','pres','temp','rho','z_mc','z_ifc','u','v','tke','qv','qc','qi','qr','qs','qg','qnc','qni','qnr','qns','qng'"
inst_ml_varlist="'pres_sfc','t_g','u_10m','v_10m','umfl_s','vmfl_s','lhfl_s','shfl_s','tot_prec_rate','pres','temp','rho','z_mc','z_ifc','qv','qc','qi','qr','qs','qg','qnc','qni','qnr','qns','qng'"
hourly_hl_varlist="'pres','temp','rho','u','v','w','rh','tke','qv','qc','qi','qr','qs','qg','qnc', 'qni','qnr','qns','qng'"

# Overwrite default settings with the experiment configuration.
. "exp/$expname"

# ----------------------------------------------------------------------------
# path definitions
# ----------------------------------------------------------------------------

# base directory for ICON sources and binary:
icondir=$(realpath "${icondir:=src/ICON_DWD_NWP_DEPHY}")

# directory with input grids:
griddir=$(realpath input)

# directory with init files:
initdir=$(realpath input)

# absolute path to output directory for results:
expdir=$(realpath "runs/$expname")

# path to model binary, including the executable:
model=$icondir/bin/icon

# ----------------------------------------------------------------------------
# model timing
# ----------------------------------------------------------------------------

start_date=${start_date:=2020-03-12T22:00:00Z}
end_date=${end_date:=2020-03-13T18:00:00Z}

# 0.4 s for 70 m res., 0.5 for 100 m; 30 s for 2.5 km?
dtime=0.5                        # 0.5 200m, 0.25 100m
ndyn_substeps=5                  # default: 5
start_date_jd=$(aq iso jd "$start_date")
end_date_jd=$(aq iso jd "$end_date")
nsteps=$(echo "($end_date_jd - $start_date_jd)*24*60*60/$dtime" | bc)

# ----------------------------------------------------------------------------
# grid namelist settings
# ----------------------------------------------------------------------------

# the grid parameters
grid_name=${grid_name:=Torus_Triangles_10x10_100m}
atmo_dyn_grids=grid.nc

# reconstruct the grid parameters in namelist form
dynamics_grid_filename=""
for gridfile in ${atmo_dyn_grids}; do
  dynamics_grid_filename="${dynamics_grid_filename} '${gridfile}',"
done
radiation_grid_filename=""
for gridfile in ${atmo_rad_grids}; do
  radiation_grid_filename="${radiation_grid_filename} '${gridfile}',"
done

ecRad_data_path=$(realpath "$icondir/externals/ecrad/data")

# --- 80m resolution to 7000m
# &run_nml
#  num_lev        = 87        ! number of full levels of vertical grid
# &nonhydrostatic_nml
#  ivctype        = 2         ! sleve vertical coordinate
#  damp_height    = 5000.     ! top_height-damp_height should be about 15km
#  l_open_ubc     = .false.   ! top open upper boundary condition. might help to go higher
#  rayleigh_coeff = 0.0
#  htop_moist_proc= 22500.
#  hbot_qvsubstep	= 22500.    ! Default: 22500  ! M. Koehler: 19000; at least as large as htop_moist_proc
# /
#
# &sleve_nml
#  top_height    = 7000.
#  min_lay_thckn = -40.       ! thickness of lowest model layer
# /

# ----------------------------------------------------------------------------
# copy input data: grids, external parameters, model
# ----------------------------------------------------------------------------

# the directory for the experiment will be created, if not already there
mkdir -p "$expdir"

# grid
ln -sf "$griddir/$grid_name.nc" "$expdir/grid.nc"

# initial condition and forcing
ln -sf "$initdir/$file_dephy" "$expdir/init_SCM.nc"

# files needed for radiation
ln -sf "$icondir/data/ECHAM6_CldOptProps.nc" "$expdir/rrtm_cldopt.nc"
ln -sf "$icondir/data/ECHAM6_CldOptProps.nc" "$expdir"
ln -sf "$icondir/data/rrtmg_lw.nc" "$expdir"
ln -sf "$icondir/data/rrtmg_sw.nc" "$expdir"
ln -sf "$icondir/data/dmin_wetgrowth_lookup.nc" "$expdir"
ln -sf "$icondir/run/ana_varnames_map_file.txt" "$expdir"
ln -sf "$icondir/run/dict.latbc" "$expdir"

ln -sf "$model" "$expdir/icon"

nl_master > "$expdir/icon_master.namelist"
nl > "$expdir/icon.namelist"

# ----------------------------------------------------------------------------
# run the model!
# ----------------------------------------------------------------------------

cd "$expdir"
$START icon
cd -

echo 'start time:' "$starttime"
echo 'end time:' $(date)



# Constants.
k = 0.4  # van Karman constant (1).
g = 9.80665  # Gravitational acceleration (m s-2).
rd = 287.04  # Specific gas constant of dry air (J kg-1 K-1).
cpd = 1004.64  # Heat capcity of dry air at constant presssure (J kg-1 K-1).
p0ref = 100000.0  # Atmospheric reference pressure (Pa).
delt = 60.0  # Conversion of minutes to seconds (s min-1).


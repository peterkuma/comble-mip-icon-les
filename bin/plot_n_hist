#!/usr/bin/env python3
'''Plot histogram a hydrometeor number concentration.

Usage: plot_n_hist VAR T1 T2 INPUT OUTPUT TITLE

Arguments:

  VAR     Variable.
  T1      Start time step.
  T2      End time step.
  INPUT   Input file (mean output of ICON).
  OUTPUT  Output plot.
  TITLE   Plot title.
'''

import sys
import numpy as np
import matplotlib as mpl
import matplotlib.pyplot as plt
import ds_format as ds

LABEL = {
	'qnc': 'Cloud liquid number concentration (cm$^{-3}$)',
	'qni': 'Cloud ice number concentration (L$^{-1}$)',
}

MUL = {
	'qnc': 1e-6,
	'qni': 1e-3,
}

mpl.rc('font', family='Open Sans')
mpl.rc('axes', linewidth=0.3)
#mpl.rc('axes', grid=True)
mpl.rc('lines', linewidth=1.2)
mpl.rc('xtick.major', width=0.3)
mpl.rc('ytick.major', width=0.3)
mpl.rc('legend', framealpha=1)
mpl.rc('legend', facecolor='#eeeeee')
mpl.rc('legend', edgecolor='none')
mpl.rc('legend', fancybox=False)
mpl.rc('legend', fontsize=7)
mpl.rc('grid', color='k')
mpl.rc('grid', alpha=0.2)
mpl.rc('grid', lw=0.1)

#NCELLS = 10
NCELLS = None

if __name__ == '__main__':
	if len(sys.argv) != 7:
		sys.stderr.write(sys.modules[__name__].__doc__)
		sys.exit(1)
	var = sys.argv[1]
	t1 = int(sys.argv[2])
	t2 = int(sys.argv[3])
	input_ = sys.argv[4]
	output = sys.argv[5]
	title = sys.argv[6]
	d = ds.read(input_, [], full=True)
	ncells = ds.dim(d, 'ncells', full=True)
	n = ds.dim(d, 'time', full=True)
	size = NCELLS if NCELLS is not None else ncells
	sel_cells = np.random.randint(0, ncells, size=size)
	yy = []
	for i in range(t1, t2):
		print(i)
		d = ds.read(input_, [var, 'rho', 'qc', 'qr', 'temp'],
			sel={'time': i, 'ncells': sel_cells}
		)
		x = d[var]
		mask = ((d['qc'] + d['qr']) > 1e-6) & (d['temp'] < 268.15)
		y = x[mask]*d['rho'][mask]*MUL[var]
		yy += list(y)
	plt.hist(yy, density=True, color='#116eff', bins=np.arange(0, 50, 1))
	plt.xlabel(LABEL[var])
	plt.ylabel('Frequency')
	plt.title(title + (' (%d rand. cells, tstep %d–%d)' % (size, t1, t2 - 1)))
	plt.savefig(output, bbox_inches='tight')
